# BIGRONJONES — Environment Configuration Template
# Copy this file to .env and fill in your values

# ---------------------------------------------------------------------------
# Frontend & Site Configuration
# ---------------------------------------------------------------------------
SITE_URL=https://www.bigronjones.com

# Backend API URL (Render deployment)
# Local development: http://localhost:8081
# Production: https://bigronjones-backend.onrender.com
VITE_API_URL=https://bigronjones-backend.onrender.com

# ---------------------------------------------------------------------------
# Supabase (PostgreSQL Database & Auth)
# Get from: Supabase → Settings → API Keys
# ---------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ---------------------------------------------------------------------------
# Stripe (Payments) — LIVE KEYS FOR PRODUCTION
# Get from: Stripe Dashboard → Developers → API Keys
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_51Q5Vd7...
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_51Q5Vd7...
STRIPE_CHECKOUT_LINK=https://buy.stripe.com/...

# ---------------------------------------------------------------------------
# Email Configuration
# ---------------------------------------------------------------------------
# Gmail SMTP (recommended - free, reliable)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password  # Generate at myaccount.google.com/apppasswords

SMTP_FROM_NAME=Big Ron Jones
RESEND_FROM_EMAIL=Big Ron Jones <ron@bigronjones.com>
CONTACT_INBOX_EMAIL=hello@bigronjones.com

# Resend API (optional fallback)
RESEND_API_KEY=re_...
RESEND_AUDIENCE_ID=

# ---------------------------------------------------------------------------
# AI & Third-Party APIs
# ---------------------------------------------------------------------------
GOOGLE_API_KEY=  # For blog generation (optional)
CALENDLY_WEBHOOK_SECRET=  # For trial registration (optional)

# ---------------------------------------------------------------------------
# Security & Admin
# ---------------------------------------------------------------------------
CRON_SECRET=789d823513cccf77866c6629345fcb4d07d2b43dd559ba22ab77f934c3d3f0d5

# Admin access (comma-separated emails)
ADMIN_EMAILS=manishsinghchouhan13@gmail.com
VITE_ADMIN_EMAILS=manishsinghchouhan13@gmail.com
SUPER_ADMIN_EMAILS=manishsinghchouhan13@gmail.com

# ---------------------------------------------------------------------------
# Site
# ---------------------------------------------------------------------------
SITE_URL=https://bigronjones.com

# ---------------------------------------------------------------------------
# Supabase (lead-funnel storage)
#   Get these from Supabase → Settings → API.
#   The service-role key bypasses RLS — never expose it to the browser.
# ---------------------------------------------------------------------------
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ---------------------------------------------------------------------------
# Supabase Browser Client (Frontend)
#   Get the ANON KEY from Supabase → Settings → API (public anon key)
#   NEVER use the service-role key here — it would leak to the browser.
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...


# ---------------------------------------------------------------------------
# Resend (transactional + marketing email)
# ---------------------------------------------------------------------------
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Big Ron Jones <ron@bigronjones.com>
RESEND_AUDIENCE_ID=                # optional — used by /api/newsletter
CONTACT_INBOX_EMAIL=hello@bigronjones.com

# ---------------------------------------------------------------------------
# Stripe (existing checkout flow)
#   Dev:  sk_test_... / pk_test_...
#   Prod: sk_live_... / pk_live_...
#   If you EVER paste an sk_live key into a chat, log, or screenshot, treat
#   it as compromised and roll it immediately at:
#     https://dashboard.stripe.com/apikeys
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Get VITE_STRIPE_PUBLISHABLE_KEY from Stripe Dashboard → Developers → API Keys → Publishable Key

# ---------------------------------------------------------------------------
# Stripe Webhook signing secret (REQUIRED for live mode)
#   Without this, /api/webhooks/stripe rejects every event and customers who
#   close the tab on the Stripe confirmation page stay stuck at payment_status
#   = "pending" forever — i.e. "I paid but the site still asks me to buy".
#
#   Dev:  `stripe listen --forward-to localhost:8081/api/webhooks/stripe`
#         prints a whsec_… secret on first run. Paste it here.
#   Prod: Stripe Dashboard → Developers → Webhooks → Add endpoint
#         URL: https://YOUR-DOMAIN/api/webhooks/stripe
#         Events:
#           checkout.session.completed
#           checkout.session.async_payment_succeeded
#           checkout.session.async_payment_failed
#           checkout.session.expired
#         The signing secret shown after "Add endpoint" is DIFFERENT from
#         the CLI one — use the dashboard one in prod.
# ---------------------------------------------------------------------------
STRIPE_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Google Generative AI (existing /api/generate-blogs)
# ---------------------------------------------------------------------------
GOOGLE_API_KEY=

# ---------------------------------------------------------------------------
# Cron protection (used by /api/send-sequence and /api/cron/email-scheduler)
#   Generate: openssl rand -hex 32
# ---------------------------------------------------------------------------
CRON_SECRET=

# ---------------------------------------------------------------------------
# Calendly Webhook (7-Day Trial System)
#   Get this from Calendly → Integrations → Webhooks
#   Used to validate webhook signatures (HMAC SHA256)
# ---------------------------------------------------------------------------
CALENDLY_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Stripe (Checkout Links for Trial Conversion)
#   Link to upgrade from trial to paid program
#   Get this from Stripe Dashboard → Payment Links
# ---------------------------------------------------------------------------
STRIPE_CHECKOUT_LINK=https://buy.stripe.com/...

# ---------------------------------------------------------------------------
# Frontend (Vite)
#   Only VITE_-prefixed vars are exposed to the browser.
#   VITE_SITE_URL is used for OAuth redirects (Supabase Google login, etc.)
#   Must be whitelisted in Supabase Auth → Redirect URLs
# ---------------------------------------------------------------------------
VITE_SITE_URL=https://YOUR-DOMAIN.com
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
VITE_GA_ID=
