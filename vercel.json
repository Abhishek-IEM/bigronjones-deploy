{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "root": ".",
  "functions": {
    "backend/api/**/*.ts": {
      "runtime": "@vercel/node@5.1.0"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/backend/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/email-scheduler",
      "schedule": "0 6 * * *"
    }
  ]
}
