{
  "buildCommand": "npm run build:frontend",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "env": [
    "VITE_STRIPE_PUBLISHABLE_KEY",
    "VITE_ADMIN_EMAILS",
    "VITE_API_URL",
    "SITE_URL"
  ],
  "rewrites": [
    { "source": "/((?!_next|_static|assets).*)", "destination": "/index.html" }
  ]
}
